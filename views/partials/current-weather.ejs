<%- include('header.ejs', {titleDual:{ top: 'Condizioni' , bottom: 'Attuali' }, noaaLogo: false, hasTime: true}) %>
	<div class="main has-scroll has-box current-weather">
		<div class="weather template">
			<div class="left col">
				<div class="temp center"></div>
				<div class="condition center"></div>
				<div class="icon center"><img src="" /></div>
				<div class="wind-container">
					<div class="wind-label">Vento:</div>
					<div class="wind"></div>
				</div>
				<div class="wind-gusts"></div>
			</div>
			<div class="right col">
				<div class="location"></div>
				<div class="row">
					<div class="label">Umidità:</div>
					<div class="humidity value"></div>
				</div>
				<div class="row">
					<div class="label">P. Rugiada:</div>
					<div class="dewpoint value"></div>
				</div>
				<div class="row">
					<div class="label">Copertura:</div>
					<div class="ceiling value"></div>
				</div>
				<div class="row">
					<div class="label">Visibilità:</div>
					<div class="visibility value"></div>
				</div>
				<div class="row">
					<div class="label">Pressione:</div>
					<div class="pressure value"></div>
				</div>
				<div class="row">
					<div class="label">Nuvolosità:</div>
					<div class="cloud value"></div>
				</div>
				<div class="row">
					<div class="label">Indice UV:</div>
					<div class="uv value"></div>
				</div>
				<div class="row">
					<div class="heat-index-label label"></div>
					<div class="heat-index value"></div>
				</div>
			</div>
		</div>
	</div>
	<%- include('scroll.ejs') %>
